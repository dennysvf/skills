# ============================================================
# pdf-to-epub — translation configuration (translate_epub.py)
# ============================================================
# Copy this file to `.env` in your working directory and fill in
# ONLY the provider you use. NEVER commit the real `.env` file —
# add `.env` to your .gitignore.
#
# Provider and model are configured EXCLUSIVELY via environment
# (shell or this .env file) — never via CLI flags, so credentials
# and model names don't leak into shell history.

# --- Which provider to use ---
# One of: anthropic | openai | google | deepseek | xai
LLM_PROVIDER=anthropic

# --- Which model to use ---
# Budget models (Flash/Mini/Lite tiers) are usually enough for
# technical prose. Check current model names/prices on the
# provider's site before translating a large book.
LLM_MODEL=claude-haiku-4-5

# --- API key for the ACTIVE provider (uncomment only one) ---
ANTHROPIC_API_KEY=sk-ant-...

# OPENAI_API_KEY=sk-...

# GOOGLE_API_KEY=...
# (GEMINI_API_KEY is also accepted for provider "google")
# GEMINI_API_KEY=...

# DEEPSEEK_API_KEY=...

# XAI_API_KEY=...
